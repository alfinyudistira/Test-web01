{
  "name": "pulse-hiring-intelligence",
  "version": "5.0.0",
  "description": "Pulse Hiring Intelligence — Enterprise-Grade Universal SaaS Platform for Global Talent Acquisition",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -b && cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "security:audit": "pnpm audit --audit-level=high",
    "prepare": "husky install"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@reduxjs/toolkit": "^2.5.0",
    "@rjsf/core": "^5.23.1",
    "@rjsf/validator-ajv8": "^5.23.1",
    "@tanstack/react-query": "^5.67.0",
    "@tanstack/react-router": "^1.167.12",
    "@tanstack/react-table": "^8.21.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.0.0",
    "deepmerge": "^4.3.1",
    "flagged": "^3.0.0",
    "framer-motion": "^12.5.0",
    "fuse.js": "^7.1.0",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-http-backend": "^3.0.0",
    "idb-keyval": "^6.2.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.503.0",
    "nanoid": "^5.1.0",
    "pino": "^9.6.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-error-boundary": "^5.0.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.4.0",
    "react-redux": "^9.2.0",
    "react-use": "^17.6.0",
    "recharts": "^2.15.0",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "use-debounce": "^10.0.4",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.8",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.0.8",
    "@vitest/ui": "^3.0.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
